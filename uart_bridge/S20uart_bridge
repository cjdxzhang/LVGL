#!/bin/sh

DAEMON=/usr/bin/uart_bridge
NAME=uart_bridge

start() {
	if [ ! -x "$DAEMON" ]; then
		echo "$NAME: $DAEMON not found"
		return 1
	fi

	echo "Starting $NAME"
	# "$DAEMON" &
}

stop() {
	echo "Stopping $NAME"
	killall "$NAME" 2>/dev/null || true
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac

exit $?
